{
  "manifest_version": 3,
  "name": "Long-Term Stock Analyzer",
  "version": "1.0",
  "description": "long-term investing model with popup",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Stock Analyzer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches":   ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}